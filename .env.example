# =============================================================================
# Mosaic Website — Environment Variables (TEMPLATE)
# =============================================================================
#
# HOW TO USE THIS FILE
#   1. Copy it to a new file named ".env.local"  (the setup script does this for you)
#   2. Fill in the values you were given.
#   3. Never commit ".env.local" — it holds secrets. (Only THIS template is committed.)
#
# WHICH VALUES DO I NEED?
#   It depends on what you're working on:
#
#   • VOLUNTEERS / most contributors (design, content, page layout):
#       You only need ONE value: mosaic_REDIS_URL  (see "EVERYDAY" below).
#       The site reads its live data (events, sermons, groups) from Redis, so this
#       single value is enough to see the real site running on your computer.
#       You do NOT need any of the keys under "OWNER-ONLY".
#
#   • OWNER / maintainer (running data syncs, deploys, integrations):
#       You need everything below.
#
# Ask the person who invited you for the value(s) you need. Paste them after the
# "=" signs, with no spaces and no quotes.
# =============================================================================


# -----------------------------------------------------------------------------
# EVERYDAY — needed by everyone to run the site locally
# -----------------------------------------------------------------------------

# Redis (the site's data cache — "short-term memory").
# This is the only secret a volunteer needs. Ideally you'll be given a
# READ-ONLY Redis URL so local work can never change live data.
mosaic_REDIS_URL=

# Sanity content CMS — these two are PUBLIC ids (safe to share), not secrets.
# Leave the project id blank until the Sanity project has been created.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production


# -----------------------------------------------------------------------------
# OWNER-ONLY — needed for data syncing, integrations, and deploys.
# Volunteers can ignore everything below this line.
# -----------------------------------------------------------------------------

# Planning Center (PCO) — Personal Access Token (App ID + Secret).
# Source of events/groups/people; also where website forms are written.
PCO_APP_ID=
PCO_SECRET=

# YouTube Data API v3 key (Google Cloud Console) — sermon videos + live status.
YOUTUBE_API_KEY=

# Spotify Web API (Client Credentials) — matches sermons to podcast episodes.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Shared secret that protects the scheduled sync endpoint (/api/cron/sync).
# Vercel sets this automatically in production; only needed locally to test cron.
CRON_SECRET=

# Sanity write token (SECRET) — needed only to push content from code, not to read.
SANITY_API_TOKEN=
